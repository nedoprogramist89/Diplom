# Скопируйте в .env и заполните значения
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Для HTTPS на сервере (через запятую, с https://):
# CSRF_TRUSTED_ORIGINS=https://your-domain.ru,https://www.your-domain.ru

# Порт встроенного сервера разработки (по умолчанию в проекте — 8888)
# RUNSERVER_PORT=8888

# Для запуска без PostgreSQL (только для проверки) задайте USE_SQLITE=1
# USE_SQLITE=1

# PostgreSQL (локально или российский хостинг)
DB_NAME=competitions_db
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Почта (восстановление пароля, тестовое письмо в профиле)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=noreply@example.com
# EMAIL_HOST_PASSWORD=app-password
# DEFAULT_FROM_EMAIL=noreply@example.com
